generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id             String   @id @default(cuid())
  nickname       String
  joinedByEmail  String?
  joinedByName   String?
  inviteCodeHash String?
  inviteCodeUpdatedAt DateTime?
  tokenEncrypted String
  tokenIv        String
  tokenTag       String
  wkUserId       String   @unique
  wkUsername     String
  wkLevel        Int
  reviewCount    Int      @default(0)
  burnedCount    Int      @default(0)
  pendingReviews Int      @default(0)
  radicalCount   Int      @default(0)
  vocabularyCount Int     @default(0)
  apprenticeCount Int     @default(0)
  guruCount       Int     @default(0)
  masterCount     Int     @default(0)
  enlightenedCount Int    @default(0)
  levelKanjiTotal Int     @default(0)
  levelKanjiLearned Int   @default(0)
  levelKanjiGuruPlus Int  @default(0)
  levelKanjiLocked Int    @default(0)
  estimatedHoursRemaining Int?
  levelKanjiItems Json?
  itemSpread      Json?
  jlptCounts      Json?
  assignmentCache Json?
  assignmentCacheUpdatedAt DateTime?
  reviewsUpdatedAt DateTime?
  lastRadicalGuruedAt DateTime?
  lastKanjiGuruedAt DateTime?
  lastVocabularyGuruedAt DateTime?
  lastRadicalGuruedItem Json?
  lastKanjiGuruedItem Json?
  lastVocabularyGuruedItem Json?
  wkHttpCache     Json?
  lastActivityAt  DateTime?
  isSyncing       Boolean  @default(false)
  syncLockUntil   DateTime?
  nextSyncAllowedAt DateTime @default(now())
  lastSyncStatus  String   @default("idle")
  lastSyncError   String?
  score          Int      @default(0)
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customStudyLibraries      CustomStudyLibrary[]
  customStudyStates         CustomStudyState[]
  customStudyReviewAttempts CustomStudyReviewAttempt[]
}

model LevelSnapshot {
  id                String   @id @default(cuid())
  accountId         String
  level             Int
  kanjiTotal        Int      @default(0)
  kanjiLearned      Int      @default(0)
  kanjiGuruPlus     Int      @default(0)
  kanjiLocked       Int      @default(0)
  estimatedHoursRemaining Int?
  items             Json?
  syncedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, level])
  @@index([accountId])
}

model DailyAccountSnapshot {
  id                 String   @id @default(cuid())
  accountId          String
  snapshotDatePst    String
  snapshotAt         DateTime @default(now())
  wkLevel            Int
  reviewCount        Int
  burnedCount        Int
  pendingReviews     Int
  radicalCount       Int
  vocabularyCount    Int
  apprenticeCount    Int
  guruCount          Int
  masterCount        Int
  enlightenedCount   Int
  levelKanjiLearned  Int
  levelKanjiTotal    Int
  score              Int
  lastActivityAt     DateTime?
  lastSyncedAt       DateTime

  @@unique([accountId, snapshotDatePst])
  @@index([accountId])
}

model JlptKanji {
  id        String   @id @default(cuid())
  kanji     String   @unique
  nLevel    Int
  strokeCount Int?
  frequencyRank Int?
  schoolGrade Int?
  heisigKeyword String?
  unicodeHex String?
  sourceJlpt Int?
  primaryMeaning String?
  meanings   String[] @default([])
  onReadings String[] @default([])
  kunReadings String[] @default([])
  nanoriReadings String[] @default([])
  notes String[] @default([])
  wordExamples Json?
  enrichedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nLevel])
}

model WkSubjectCatalog {
  wkSubjectId               Int      @id
  object                    String   @default("subject")
  subjectType               String
  level                     Int
  slug                      String?
  characters                String?
  documentUrl               String?
  dataUpdatedAt             DateTime
  hiddenAt                  DateTime?
  meanings                  Json?
  readings                  Json?
  componentSubjectIds       Int[]    @default([])
  amalgamationSubjectIds    Int[]    @default([])
  visuallySimilarSubjectIds Int[]    @default([])
  meaningMnemonic           String?
  meaningHint               String?
  readingMnemonic           String?
  readingHint               String?
  rawData                   Json
  documentVersion           Int      @default(1)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([subjectType, level])
  @@index([level])
  @@index([dataUpdatedAt])
  @@index([hiddenAt])
}

model WkCatalogSyncState {
  id                           String              @id @default("global")
  isSyncing                    Boolean             @default(false)
  syncLockUntil                DateTime?
  nextSyncAllowedAt            DateTime            @default(now())
  lastStatus                   WkCatalogSyncStatus @default(idle)
  lastError                    String?
  lastFullSyncStartedAt        DateTime?
  lastFullSyncCompletedAt      DateTime?
  lastIncrementalSyncStartedAt DateTime?
  lastIncrementalSyncCompletedAt DateTime?
  lastCursorDataUpdatedAt      DateTime?
  lastCursorSubjectId          Int?
  lastRunStats                 Json?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
}

model WkCatalogSyncRun {
  id                      String               @id @default(cuid())
  runType                 WkCatalogSyncRunType
  status                  WkCatalogSyncStatus  @default(running)
  startedAt               DateTime             @default(now())
  completedAt             DateTime?
  durationMs              Int?
  cursorFromDataUpdatedAt DateTime?
  cursorFromSubjectId     Int?
  cursorToDataUpdatedAt   DateTime?
  cursorToSubjectId       Int?
  fetchedCount            Int                  @default(0)
  upsertedCount           Int                  @default(0)
  changedCount            Int                  @default(0)
  errorCount              Int                  @default(0)
  errorMessage            String?
  stats                   Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([runType, startedAt])
  @@index([status, startedAt])
}

enum StudyReviewResult {
  correct
  wrong
  skipped
}

enum WkCatalogSyncStatus {
  idle
  running
  ok
  error
}

enum WkCatalogSyncRunType {
  full
  incremental
}

enum SubjectReviewSnapshotSource {
  sync
  ondemand
  submit
}

enum ReadingChallengeStatus {
  draft
  active
  completed
  archived
}

enum CustomStudySourceType {
  json_upload
}

enum CustomStudyItemType {
  kanji
  vocabulary
  phrase
}

model ReadingChallenge {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String
  description   String
  status        ReadingChallengeStatus @default(draft)
  currencyCode  String                @default("JPY")
  startDatePst  String
  goalDatePst   String
  tripDatePst   String
  targetBaseYen Int
  scoringRules  Json
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  signoffs      ReadingSignoff[]
  signoffEntries ReadingSignoffEntry[]
  books         ReadingChallengeBook[]
  members       ReadingChallengeMember[]

  @@index([status])
  @@index([startDatePst, goalDatePst])
}

model StudyReviewAttempt {
  id           String            @id @default(cuid())
  accountId    String
  assignmentId Int
  subjectId    Int
  subjectType  String
  result       StudyReviewResult
  submittedAt  DateTime          @default(now())

  @@index([accountId, subjectId, submittedAt])
  @@index([accountId, submittedAt])
}

model SubjectReviewStatsSnapshot {
  id                    String                      @id @default(cuid())
  accountId             String
  subjectId             Int
  subjectType           String
  meaningCorrect        Int
  meaningIncorrect      Int
  meaningCurrentStreak  Int
  meaningMaxStreak      Int
  readingCorrect        Int
  readingIncorrect      Int
  readingCurrentStreak  Int
  readingMaxStreak      Int
  percentageCorrect     Int
  capturedAt            DateTime                    @default(now())
  source                SubjectReviewSnapshotSource @default(ondemand)

  @@index([accountId, subjectId, capturedAt])
  @@index([accountId, capturedAt])
}

model ReadingSignoff {
  id                 String   @id @default(cuid())
  challengeId        String?
  accountId          String
  signoffDatePst     String
  bookTitle          String
  pagesRead          Int
  minutesRead        Int
  didWanikaniReviews Boolean  @default(false)
  reviewsLeft        Int
  apprenticeCount    Int
  currentWkLevel     Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  challenge          ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([accountId, signoffDatePst])
  @@index([challengeId, accountId])
  @@index([signoffDatePst])
  @@index([accountId])
}

model ReadingSignoffEntry {
  id                   String   @id @default(cuid())
  challengeId          String?
  accountId            String
  signoffDatePst       String
  bookTitle            String
  pagesRead            Int
  minutesRead          Int
  didWanikaniReviews   Boolean  @default(false)
  reviewWorkDone       Int      @default(0)
  reviewCorrect        Int      @default(0)
  reviewIncorrect      Int      @default(0)
  reviewSuccessPercent Int?
  createdAt            DateTime @default(now())

  challenge            ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@index([challengeId, accountId, signoffDatePst])
  @@index([accountId, signoffDatePst])
  @@index([accountId, createdAt])
  @@index([signoffDatePst])
}

model ReadingChallengeBook {
  id              String   @id @default(cuid())
  challengeId     String?
  accountId       String
  isbn            String
  title           String
  thumbnailUrl    String?
  manualCoverUrl  String?
  infoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  challenge    ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([accountId, isbn, challengeId])
  @@index([challengeId, accountId])
  @@index([accountId])
}

model ReadingChallengeMember {
  id        String   @id @default(cuid())
  challengeId String?
  accountId String
  tracked   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challenge ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([challengeId, accountId])
  @@index([challengeId, accountId])
  @@index([accountId])
}

model CustomStudyLibrary {
  id            String                @id @default(cuid())
  accountId     String
  externalKey   String
  name          String
  description   String?
  schemaVersion Int                   @default(1)
  sourceType    CustomStudySourceType @default(json_upload)
  itemCount     Int                   @default(0)
  isActive      Boolean               @default(false)
  lastImportedAt DateTime             @default(now())
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  account        Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  items          CustomStudyItem[]
  states         CustomStudyState[]
  reviewAttempts CustomStudyReviewAttempt[]

  @@unique([accountId, externalKey])
  @@index([accountId, isActive])
}

model CustomStudyItem {
  id              Int                 @id @default(autoincrement())
  libraryId       String
  externalId      String
  itemType        CustomStudyItemType
  wkLevel         Int                 @default(1)
  characters      String
  meanings        String[]
  readings        String[]            @default([])
  primaryReading  String?
  meaningMnemonic String?
  readingMnemonic String?
  synonyms        String[]            @default([])
  notes           String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  library        CustomStudyLibrary       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  states         CustomStudyState[]
  reviewAttempts CustomStudyReviewAttempt[]

  @@unique([libraryId, externalId])
  @@index([libraryId, itemType])
  @@index([libraryId, wkLevel])
}

model CustomStudyState {
  id            Int      @id @default(autoincrement())
  accountId     String
  libraryId     String
  itemId        Int
  srsStage      Int      @default(0)
  availableAt   DateTime?
  unlockedAt    DateTime?
  startedAt     DateTime?
  passedAt      DateTime?
  burnedAt      DateTime?
  lastReviewedAt DateTime?
  reviewCount   Int      @default(0)
  correctCount  Int      @default(0)
  wrongCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account        Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  library        CustomStudyLibrary       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  item           CustomStudyItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reviewAttempts CustomStudyReviewAttempt[]

  @@unique([accountId, itemId])
  @@index([accountId, libraryId, srsStage, availableAt])
  @@index([accountId, libraryId, updatedAt])
}

model CustomStudyReviewAttempt {
  id               String            @id @default(cuid())
  accountId        String
  libraryId        String
  stateId          Int
  itemId           Int
  result           StudyReviewResult
  previousSrsStage Int?
  newSrsStage      Int?
  submittedAt      DateTime          @default(now())

  account Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  library CustomStudyLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  state   CustomStudyState   @relation(fields: [stateId], references: [id], onDelete: Cascade)
  item    CustomStudyItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([accountId, libraryId, submittedAt])
  @@index([accountId, itemId, submittedAt])
}
